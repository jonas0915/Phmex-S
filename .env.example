# Exchange API credentials
EXCHANGE=phemex
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Trading configuration
TRADING_PAIRS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT
BASE_CURRENCY=USDT
LEVERAGE=12
TRADE_AMOUNT_USDT=70.0         # Fixed USDT margin per trade
MAX_OPEN_TRADES=3
MAX_DRAWDOWN_PERCENT=10.0      # Stop bot if drawdown exceeds this

# Strategy selection: momentum, mean_reversion, breakout, combined
STRATEGY=combined

# Timeframe: 1m, 5m, 15m, 1h, 4h, 1d
TIMEFRAME=15m

# Risk management
STOP_LOSS_PERCENT=2.0
TAKE_PROFIT_PERCENT=4.0
TRAILING_STOP=true
TRAILING_STOP_OFFSET=1.0

# Mode: live, paper
MODE=paper

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
